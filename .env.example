# Copy to .env.local and set values. Do not commit .env or .env.local.
# For Firebase App Hosting: set these in Firebase Console → App Hosting → Backend → Settings → Environment.

# Canonical site URL for SEO, sitemap, and OG images (e.g. https://evomotorsinc.com)
# NEXT_PUBLIC_SITE_URL=https://evomotorsinc.com

# Vehiclix storefront API.
# REQUIRED in production. Must be a live HTTPS origin (never localhost / ngrok / tunnel).
# NEXT_PUBLIC_VEHICLIX_API_URL=https://api.vehiclix.app

# Dealer identifier for API paths and auth bridge context.
# REQUIRED in production.
# NEXT_PUBLIC_DEALER_SLUG=evo-motors

# --- Auth bridge (Vehiclix app / login / portal) ---
# Base URL for Vehiclix app. Used for login/register/portal when specific URLs are unset.
# In production this must be a live origin (never localhost / ngrok / tunnel).
# NEXT_PUBLIC_VEHICLIX_APP_URL=https://app.evomotorsinc.com
# Legacy: same as APP_URL if VEHICLIX_APP_URL is unset.
# NEXT_PUBLIC_LOGIN_APP_URL=https://app.evomotorsinc.com
# Optional overrides (default: APP_URL + path):
# NEXT_PUBLIC_VEHICLIX_LOGIN_URL=https://app.evomotorsinc.com/login
# NEXT_PUBLIC_VEHICLIX_REGISTER_URL=https://app.evomotorsinc.com/register
# NEXT_PUBLIC_VEHICLIX_PORTAL_URL=https://app.evomotorsinc.com/portal

# --- Homepage v2 rollout ---
# NEXT_PUBLIC_HOME_V2=true

# --- Business NAP (local SEO) ---
# NEXT_PUBLIC_BUSINESS_PHONE=(510) 555-0100
# NEXT_PUBLIC_BUSINESS_PHONE_TEL=+15105550100
# NEXT_PUBLIC_BUSINESS_HOURS_DISPLAY=Mon–Fri 9am–6pm · Sat 10am–4pm
# NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.google.com/?q=...
# NEXT_PUBLIC_GBP_URL=https://g.page/...
# NEXT_PUBLIC_GEO_LAT=37.9681
# NEXT_PUBLIC_GEO_LNG=-122.2952

# --- Analytics & Search Console ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GSC_VERIFICATION=your-verification-token
